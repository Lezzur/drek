# DREK environment template — copy to .env and fill in.
# .env is gitignored. Never commit the real one.

# --- HTTP server ---
PORT=3003
NODE_ENV=development

# --- GCP / Firestore ---
# Path to the service-account JSON for DREK's own Firebase project
# (separate from Neurocore's project per the app-isolation pattern).
# Firebase Admin SDK auto-detects GOOGLE_APPLICATION_CREDENTIALS.
GOOGLE_APPLICATION_CREDENTIALS=./gcp-key.json

# GCP project ID. Duplicated from the JSON for logs/health.
GCP_PROJECT_ID=

# --- Logging ---
# pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# --- LLM provider (M1+) ---
# Active provider. Selected once at startup, application-wide.
# LLM_PROVIDER=claude
# LLM_TIMEOUT_MS=120000

# --- Neurocore integration (M2+) ---
# DREK is a Neurocore consumer. Same VPS, so loopback URL.
# NEUROCORE_URL=http://localhost:3100
# NEUROCORE_TOKEN=

# --- Polling service (M9+) ---
# How often to poll Neurocore for new PI listings. 30 minutes default.
# POLLING_INTERVAL_MS=1800000
# POLLING_ENABLED=true
