# DREK environment template — copy to .env and fill in.
# .env is gitignored. Never commit the real one.

# --- HTTP server ---
PORT=3003
NODE_ENV=development

# --- GCP / Firestore ---
# Path to the service-account JSON for DREK's own Firebase project
# (separate from Neurocore's project per the app-isolation pattern).
# Firebase Admin SDK auto-detects GOOGLE_APPLICATION_CREDENTIALS.
GOOGLE_APPLICATION_CREDENTIALS=./gcp-key.json

# GCP project ID. Duplicated from the JSON for logs/health.
GCP_PROJECT_ID=

# --- Logging ---
# pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# --- LLM provider (M1) ---
# Active provider. Selected once at startup, application-wide. Switch to
# 'codex' to route all LLM calls through the OpenAI Codex CLI instead.
LLM_PROVIDER=claude

# Wall-clock cap on a single subprocess call. 120s covers the longest step
# (script writing). Lower this for dev if you want to fail fast.
LLM_TIMEOUT_MS=120000

# Claude CLI. On Windows, point CLAUDE_BIN at the .cmd shim.
CLAUDE_BIN=claude
CLAUDE_MODEL=claude-sonnet-4-5

# Codex CLI. Set CODEX_MODEL to whatever your installed CLI accepts.
CODEX_BIN=codex
CODEX_MODEL=gpt-5-codex

# --- Neurocore integration (M2) ---
# DREK is a Neurocore consumer. Loopback URL since they're co-located.
NEUROCORE_URL=http://localhost:3100
# Bearer token issued by Neurocore's /v1/admin/tokens endpoint for DREK.
NEUROCORE_TOKEN=
# Per-call timeout. Single retry stacked on top → worst case ~2× + 2s backoff.
NEUROCORE_TIMEOUT_MS=10000

# --- Polling service (M9+) ---
# How often to poll Neurocore for new PI listings. 30 minutes default.
# POLLING_INTERVAL_MS=1800000
# POLLING_ENABLED=true
